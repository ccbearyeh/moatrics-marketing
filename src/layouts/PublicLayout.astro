---
/**
 * Root layout for the Moatrics marketing site.
 *
 * Responsibilities:
 *   - <head> SEO/OG/Twitter/JSON-LD
 *   - Font preconnect + stylesheet (Inter / Space Grotesk / JetBrains Mono)
 *   - Global CSS import (design tokens, glass primitives, container)
 *   - Sticky Navbar + Footer
 *
 * Pages pass `title`, `description`, `path` for canonical/OG URL building.
 */
import '../styles/global.css';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description: string;
  /** Path-only, leading slash. Used for canonical + og:url. e.g. "/", "/terms". */
  path?: string;
  /** Optional OG image (absolute path under /public). Defaults to /og-image.png. */
  ogImage?: string;
  /** Optional `noindex` flag for staging / legal-only pages. */
  noindex?: boolean;
}

const {
  title,
  description,
  path = '/',
  ogImage = '/og-image.png',
  noindex = false,
} = Astro.props;

const SITE_URL = 'https://moatrics.com';
const canonical = new URL(path, SITE_URL).toString();
const ogImageAbsolute = new URL(ogImage, SITE_URL).toString();

// JSON-LD: Organization schema (rendered once per page; safe to repeat)
const organizationJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'Moatrics',
  url: SITE_URL,
  logo: new URL('/moatrics-logo.png', SITE_URL).toString(),
  description:
    'Moatrics is a data-driven co-pilot for long-term value investors. Quality businesses, durable moats, margin of safety.',
  email: 'service@moatrics.com',
  contactPoint: {
    '@type': 'ContactPoint',
    email: 'service@moatrics.com',
    contactType: 'customer support',
    availableLanguage: ['en'],
  },
};

// JSON-LD: WebSite — adds site identity + search action affordance.
const websiteJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'Moatrics',
  alternateName: 'Moatrics — Value investing intelligence',
  url: SITE_URL,
  inLanguage: ['en', 'zh-Hant'],
  publisher: { '@type': 'Organization', name: 'Moatrics', url: SITE_URL },
};

// JSON-LD: BreadcrumbList — derived from `path`.
//   "/"            → [Home]
//   "/terms"       → [Home > Terms]
//   "/a/b"         → [Home > A > B]
const segments = (path === '/' ? [] : path.replace(/^\/|\/$/g, '').split('/'))
  .filter(Boolean);
const titleCase = (slug: string) =>
  slug
    .split('-')
    .map((w) => (w ? w[0].toUpperCase() + w.slice(1) : w))
    .join(' ');
const breadcrumbItems = [
  {
    '@type': 'ListItem',
    position: 1,
    name: 'Home',
    item: SITE_URL + '/',
  },
  ...segments.map((seg, i) => ({
    '@type': 'ListItem',
    position: i + 2,
    name: titleCase(seg),
    item: new URL('/' + segments.slice(0, i + 1).join('/'), SITE_URL).toString(),
  })),
];
const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: breadcrumbItems,
};
---

<!doctype html>
<html lang="en">
  <head>
    {/* ── Pre-paint language detection ────────────────────────────────────
        Runs BEFORE any visible content so `<html lang>` is correct on the
        first paint, which means our dual-render CSS (hides the inactive
        language via `html[lang="zh"] [data-i18n-lang="en"]`) never flashes
        the wrong copy. Cookie name + values match the navbar EN/中 toggle.
        Defaults to `en` if no cookie. `is:inline` ensures Astro emits this
        verbatim without bundling — required so it can run before <body>. */}
    <script is:inline>
      (function () {
        try {
          var m = document.cookie.match(/(?:^|;\s*)moatrics_lang=(en|zh)/);
          var lang = m ? m[1] : 'en';
          document.documentElement.setAttribute('lang', lang);
        } catch (e) {
          /* Cookie access can throw in some sandboxed contexts; default to en. */
          document.documentElement.setAttribute('lang', 'en');
        }
      })();
    </script>

    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#07040d" />
    <meta name="color-scheme" content="dark" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    {/* Open Graph */}
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Moatrics" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageAbsolute} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    {/* Twitter */}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageAbsolute} />

    {/* Favicon — reuse the brand logo PNG for now. A purpose-built favicon
        can ship later without touching this layout. */}
    <link rel="icon" type="image/png" href="/moatrics-logo.png" />
    <link rel="apple-touch-icon" href="/moatrics-logo.png" />

    {/* Fonts — preconnect + display=swap for fast paint */}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="preload"
      as="style"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Space+Grotesk:wght@500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap"
    />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Space+Grotesk:wght@500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap"
    />

    <script
      type="application/ld+json"
      set:html={JSON.stringify(organizationJsonLd)}
    />
    <script
      type="application/ld+json"
      set:html={JSON.stringify(websiteJsonLd)}
    />
    <script
      type="application/ld+json"
      set:html={JSON.stringify(breadcrumbJsonLd)}
    />
  </head>
  <body>
    <a href="#main" class="mx-skip-link">Skip to content</a>
    <Navbar />
    <main id="main">
      <slot />
    </main>
    <Footer />

    {/* ── Scroll-reveal observer ──────────────────────────────────────────
        Toggles `data-reveal-state="in"` on every `[data-reveal]` element as
        it enters the viewport. Matches the CSS in global.css that fades +
        slides them up. Honours `prefers-reduced-motion` (no-op there). One
        IIFE shared across all pages; no framework. */}
    <script is:inline>
      (function () {
        if (typeof window === 'undefined') return;
        var reduce = window.matchMedia
          ? window.matchMedia('(prefers-reduced-motion: reduce)').matches
          : false;
        var els = document.querySelectorAll('[data-reveal]');
        if (!els.length) return;
        if (reduce || !('IntersectionObserver' in window)) {
          els.forEach(function (el) {
            el.setAttribute('data-reveal-state', 'in');
          });
          return;
        }
        var io = new IntersectionObserver(
          function (entries) {
            entries.forEach(function (entry) {
              if (entry.isIntersecting) {
                entry.target.setAttribute('data-reveal-state', 'in');
                io.unobserve(entry.target);
              }
            });
          },
          { rootMargin: '0px 0px -10% 0px', threshold: 0.08 },
        );
        els.forEach(function (el) {
          io.observe(el);
        });
      })();
    </script>

    <style>
      .mx-skip-link {
        position: absolute;
        left: -9999px;
        top: 0;
        background: var(--mx-gold);
        color: #1a0f00;
        padding: 10px 16px;
        font-family: var(--mx-font-body);
        font-weight: 700;
        border-radius: 0 0 8px 0;
        z-index: 9999;
      }
      .mx-skip-link:focus { left: 0; }
    </style>
  </body>
</html>
