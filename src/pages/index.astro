---
/**
 * Moatrics homepage — Phase A.
 *
 * Sections (top → bottom):
 *   1. Hero with animated purple/gold gradient blobs
 *   2. Trust band ("Built around the principles…")
 *   3. Features grid (6 cards with inline SVG icons)
 *   4. How It Works (3-step process)
 *   5. Metrics band (ROIC / Debt / Growth / Margin of Safety)
 *   6. Pricing teaser (Free + Pro, monthly/annual toggle — vanilla JS)
 *   7. CTA banner
 *
 * All copy is sourced from `src/i18n/en.json` via the dotted-path `t()` helper.
 * Auth links go to https://app.moatrics.com.
 */
import PublicLayout from '../layouts/PublicLayout.astro';
import T from '../components/T.astro';
import { t, getNode } from '../i18n';

const APP_BASE = 'https://app.moatrics.com';

const featureKeys = ['moat', 'valuation', 'screener', 'watchlist', 'gurus', 'journal'] as const;
const stepKeys = ['screen', 'analyze', 'decide'] as const;
const metricKeys = ['roic', 'debt', 'growth', 'valuation'] as const;

// Pricing feature lists — fetched per-language so we can dual-render each item
// (CSS hides the language sibling that doesn't match `<html lang>`).
const freeFeaturesEn = (getNode('home.pricing_teaser.free.features', 'en') as string[]) ?? [];
const freeFeaturesZh = (getNode('home.pricing_teaser.free.features', 'zh') as string[]) ?? [];
const proFeaturesEn = (getNode('home.pricing_teaser.pro.features', 'en') as string[]) ?? [];
const proFeaturesZh = (getNode('home.pricing_teaser.pro.features', 'zh') as string[]) ?? [];

// Zip features into [en, zh] pairs (fall back to en if zh missing for a row)
const freeFeaturePairs = freeFeaturesEn.map((en, i) => [en, freeFeaturesZh[i] ?? en] as const);
const proFeaturePairs = proFeaturesEn.map((en, i) => [en, proFeaturesZh[i] ?? en] as const);

// Pricing toggle values pre-resolved in both languages — used as data-* on the
// dual-render siblings so the vanilla JS billing switcher swaps textContent
// inside whichever language sibling is currently visible.
const proPriceMonthlyEn = t('home.pricing_teaser.pro.price_monthly', 'en');
const proPriceMonthlyZh = t('home.pricing_teaser.pro.price_monthly', 'zh');
const proPriceAnnuallyEn = t('home.pricing_teaser.pro.price_annually', 'en');
const proPriceAnnuallyZh = t('home.pricing_teaser.pro.price_annually', 'zh');
const proNoteMonthlyEn = t('home.pricing_teaser.pro.billing_note_monthly', 'en');
const proNoteMonthlyZh = t('home.pricing_teaser.pro.billing_note_monthly', 'zh');
const proNoteAnnuallyEn = t('home.pricing_teaser.pro.billing_note_annually', 'en');
const proNoteAnnuallyZh = t('home.pricing_teaser.pro.billing_note_annually', 'zh');

const title = 'Moatrics — Invest in Quality Companies. Undervalued.';
const description =
  'Moatrics is a data-driven co-pilot for long-term, value-conscious investors. Quality businesses, durable moats, margin of safety.';
---

<PublicLayout title={title} description={description} path="/">
  {/* ─── 1. HERO ────────────────────────────────────────────────────────── */}
  <section class="mx-hero">
    <div class="mx-hero-blob mx-hero-blob-a" aria-hidden="true"></div>
    <div class="mx-hero-blob mx-hero-blob-b" aria-hidden="true"></div>

    <div class="mx-container mx-hero-inner">
      <T k="home.hero.eyebrow" as="span" class="mx-eyebrow" />
      <T k="home.hero.title" as="h1" class="mx-hero-title" />
      <T k="home.hero.subtitle" as="p" class="mx-hero-subtitle" />
      <div class="mx-hero-cta">
        <a class="mx-btn mx-btn-primary" href={`${APP_BASE}/signup`}>
          <T k="home.hero.cta_primary" />
        </a>
        <a class="mx-btn mx-btn-secondary" href="#how-it-works">
          <T k="home.hero.cta_secondary" />
        </a>
      </div>
    </div>
  </section>

  {/* ─── 2. TRUST BAND ──────────────────────────────────────────────────── */}
  <section class="mx-trust">
    <div class="mx-container mx-trust-inner">
      <T k="home.trust.title" as="h2" class="mx-trust-title" />
      <T k="home.trust.subtitle" as="p" class="mx-trust-sub" />
    </div>
  </section>

  {/* ─── 3. FEATURES ─────────────────────────────────────────────────────── */}
  <section class="mx-section" id="features">
    <div class="mx-container">
      <div class="mx-section-head">
        <T k="home.features.section_eyebrow" as="span" class="mx-eyebrow mx-eyebrow-purple" />
        <T k="home.features.section_title" as="h2" class="mx-section-title" />
        <T k="home.features.section_subtitle" as="p" class="mx-section-sub" />
      </div>

      <div class="mx-features-grid">
        {featureKeys.map((k) => (
          <article class="mx-feature mx-glass">
            <div class="mx-feature-icon" aria-hidden="true">
              {k === 'moat' && (
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M3 21V10l9-7 9 7v11" />
                  <path d="M9 21v-6h6v6" />
                  <path d="M3 14h18" />
                </svg>
              )}
              {k === 'valuation' && (
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M12 3v18" />
                  <path d="M5 8h14" />
                  <path d="M5 8l-2 6a4 4 0 0 0 8 0L9 8" />
                  <path d="M19 8l-2 6a4 4 0 0 0 8 0l-2-6" />
                </svg>
              )}
              {k === 'screener' && (
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M3 5h18l-7 8v6l-4-2v-4z" />
                </svg>
              )}
              {k === 'watchlist' && (
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                  <circle cx="12" cy="12" r="3" />
                  <path d="M2 12s3.5-7 10-7 10 7 10 7-3.5 7-10 7S2 12 2 12z" />
                </svg>
              )}
              {k === 'gurus' && (
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                  <circle cx="9" cy="8" r="4" />
                  <path d="M2 21v-2a5 5 0 0 1 5-5h4a5 5 0 0 1 5 5v2" />
                  <circle cx="17" cy="6" r="3" />
                  <path d="M22 21v-1a4 4 0 0 0-3-3.9" />
                </svg>
              )}
              {k === 'journal' && (
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M4 4h13a3 3 0 0 1 3 3v13a0 0 0 0 1 0 0H7a3 3 0 0 1-3-3z" />
                  <path d="M4 4v13a3 3 0 0 0 3 3" />
                  <path d="M8 8h8M8 12h8M8 16h5" />
                </svg>
              )}
            </div>
            <T k={`home.features.items.${k}.title`} as="h3" class="mx-feature-title" />
            <T k={`home.features.items.${k}.desc`} as="p" class="mx-feature-desc" />
          </article>
        ))}
      </div>
    </div>
  </section>

  {/* ─── 4. HOW IT WORKS ─────────────────────────────────────────────────── */}
  <section class="mx-section" id="how-it-works">
    <div class="mx-container">
      <div class="mx-section-head">
        <T k="home.how_it_works.section_eyebrow" as="span" class="mx-eyebrow" />
        <T k="home.how_it_works.section_title" as="h2" class="mx-section-title" />
        <T k="home.how_it_works.section_subtitle" as="p" class="mx-section-sub" />
      </div>

      <div class="mx-steps-grid">
        {stepKeys.map((k, i) => (
          <article class="mx-step mx-glass">
            <T k={`home.how_it_works.steps.${k}.label`} as="span" class="mx-step-label" />
            <T k={`home.how_it_works.steps.${k}.title`} as="h3" class="mx-step-title" />
            <T k={`home.how_it_works.steps.${k}.desc`} as="p" class="mx-step-desc" />
            {i < stepKeys.length - 1 && (
              <div class="mx-step-arrow" aria-hidden="true">→</div>
            )}
          </article>
        ))}
      </div>
    </div>
  </section>

  {/* ─── 5. METRICS BAND ─────────────────────────────────────────────────── */}
  <section class="mx-section-tight">
    <div class="mx-container">
      <T k="home.metrics.section_title" as="h2" class="mx-section-title mx-metrics-title" />
      <div class="mx-metrics-grid">
        {metricKeys.map((k) => (
          <div class="mx-metric">
            <T k={`home.metrics.items.${k}.label`} as="span" class="mx-metric-label" />
            <T k={`home.metrics.items.${k}.desc`} as="p" class="mx-metric-desc" />
          </div>
        ))}
      </div>
    </div>
  </section>

  {/* ─── 6. PRICING TEASER ───────────────────────────────────────────────── */}
  <section class="mx-section" id="pricing">
    <div class="mx-container">
      <div class="mx-section-head">
        <T k="home.pricing_teaser.section_eyebrow" as="span" class="mx-eyebrow" />
        <T k="home.pricing_teaser.section_title" as="h2" class="mx-section-title" />
        <T k="home.pricing_teaser.section_subtitle" as="p" class="mx-section-sub" />
      </div>

      <div class="mx-billing-toggle" role="tablist" aria-label="Billing cycle">
        <button
          type="button"
          role="tab"
          aria-selected="true"
          class="mx-billing-btn mx-billing-active"
          data-billing="monthly"
        >
          <T k="home.pricing_teaser.billing_monthly" />
        </button>
        <button
          type="button"
          role="tab"
          aria-selected="false"
          class="mx-billing-btn"
          data-billing="annually"
        >
          <T k="home.pricing_teaser.billing_annually" />
        </button>
      </div>

      <div class="mx-pricing-grid">
        {/* Free */}
        <article class="mx-price-card mx-glass">
          <header class="mx-price-head">
            <T k="home.pricing_teaser.free.name" as="h3" class="mx-price-name" />
            <div class="mx-price-amount">
              <T k="home.pricing_teaser.free.price" as="span" class="mx-price-num" />
              <T k="home.pricing_teaser.free.period" as="span" class="mx-price-period" />
            </div>
            <T k="home.pricing_teaser.free.tagline" as="p" class="mx-price-tag" />
          </header>
          <ul role="list" class="mx-price-list">
            {freeFeaturePairs.map(([en, zh]) => (
              <li>
                <span class="mx-price-check" aria-hidden="true">✓</span>
                <span class="mx-i18n" lang="en" data-i18n-lang="en">{en}</span>
                <span class="mx-i18n" lang="zh" data-i18n-lang="zh">{zh}</span>
              </li>
            ))}
          </ul>
          <a class="mx-btn mx-btn-secondary mx-price-cta" href={`${APP_BASE}/signup`}>
            <T k="home.pricing_teaser.free.cta" />
          </a>
        </article>

        {/* Pro */}
        <article class="mx-price-card mx-price-card-featured mx-glass">
          <span class="mx-price-badge">
            <T k="home.pricing_teaser.recommended_badge" />
          </span>
          <header class="mx-price-head">
            <T k="home.pricing_teaser.pro.name" as="h3" class="mx-price-name" />
            <div class="mx-price-amount">
              {/*
                Dual-render price number. Both EN and ZH siblings carry
                data-monthly / data-annually with their own language values, so
                the vanilla JS billing switcher swaps `textContent` on whichever
                sibling is visible (the other is `display: none` via CSS).
              */}
              <span
                class="mx-price-num mx-i18n"
                lang="en"
                data-i18n-lang="en"
                data-monthly={proPriceMonthlyEn}
                data-annually={proPriceAnnuallyEn}
              >{proPriceMonthlyEn}</span>
              <span
                class="mx-price-num mx-i18n"
                lang="zh"
                data-i18n-lang="zh"
                data-monthly={proPriceMonthlyZh}
                data-annually={proPriceAnnuallyZh}
              >{proPriceMonthlyZh}</span>
              <T k="home.pricing_teaser.pro.period" as="span" class="mx-price-period" />
            </div>
            {/* Billing-note swappable in both languages */}
            <p
              class="mx-price-tag mx-i18n"
              lang="en"
              data-i18n-lang="en"
              data-monthly={proNoteMonthlyEn}
              data-annually={proNoteAnnuallyEn}
            >{proNoteMonthlyEn}</p>
            <p
              class="mx-price-tag mx-i18n"
              lang="zh"
              data-i18n-lang="zh"
              data-monthly={proNoteMonthlyZh}
              data-annually={proNoteAnnuallyZh}
            >{proNoteMonthlyZh}</p>
            <T k="home.pricing_teaser.pro.tagline" as="p" class="mx-price-tag" />
          </header>
          <ul role="list" class="mx-price-list">
            {proFeaturePairs.map(([en, zh]) => (
              <li>
                <span class="mx-price-check" aria-hidden="true">✓</span>
                <span class="mx-i18n" lang="en" data-i18n-lang="en">{en}</span>
                <span class="mx-i18n" lang="zh" data-i18n-lang="zh">{zh}</span>
              </li>
            ))}
          </ul>
          <a class="mx-btn mx-btn-primary mx-price-cta" href={`${APP_BASE}/signup`}>
            <T k="home.pricing_teaser.pro.cta" />
          </a>
        </article>
      </div>
    </div>
  </section>

  {/* ─── 7. CTA BANNER ───────────────────────────────────────────────────── */}
  <section class="mx-section-tight">
    <div class="mx-container">
      <div class="mx-cta-banner mx-glass">
        <T k="home.cta_banner.title" as="h2" class="mx-cta-title" />
        <T k="home.cta_banner.subtitle" as="p" class="mx-cta-sub" />
        <a class="mx-btn mx-btn-primary" href={`${APP_BASE}/signup`}>
          <T k="home.cta_banner.button" />
        </a>
      </div>
    </div>
  </section>
</PublicLayout>

<style>
  /* ─── Hero ───────────────────────────────────────────────────────────── */
  .mx-hero {
    position: relative;
    padding: 120px 0 96px 0;
    overflow: hidden;
  }
  .mx-hero-inner {
    position: relative;
    z-index: 2;
    text-align: center;
    max-width: 880px;
  }
  .mx-hero-title {
    font-family: var(--mx-font-display);
    font-weight: 700;
    font-size: clamp(2.4rem, 6vw, 4.4rem);
    line-height: 1.04;
    letter-spacing: -2px;
    margin: 0 0 22px 0;
    color: var(--mx-text);
    background: linear-gradient(135deg, #fafafa 0%, #d4d4d8 60%, #fbbf24 110%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  .mx-hero-subtitle {
    font-family: var(--mx-font-body);
    font-size: clamp(1.05rem, 1.5vw, 1.2rem);
    color: var(--mx-text-muted);
    max-width: 620px;
    margin: 0 auto 36px auto;
    line-height: 1.55;
  }
  .mx-hero-cta {
    display: inline-flex;
    gap: 14px;
    flex-wrap: wrap;
    justify-content: center;
  }

  .mx-hero-blob {
    position: absolute;
    z-index: 0;
    border-radius: 50%;
    filter: blur(80px);
    opacity: 0.6;
    pointer-events: none;
  }
  .mx-hero-blob-a {
    width: 520px;
    height: 520px;
    background: radial-gradient(circle, rgba(168, 85, 247, 0.45) 0%, transparent 70%);
    top: -120px;
    left: -120px;
    animation: mxFloatA 18s ease-in-out infinite;
  }
  .mx-hero-blob-b {
    width: 460px;
    height: 460px;
    background: radial-gradient(circle, rgba(251, 191, 36, 0.32) 0%, transparent 70%);
    bottom: -140px;
    right: -100px;
    animation: mxFloatB 22s ease-in-out infinite;
  }
  @keyframes mxFloatA {
    0%, 100% { transform: translate(0, 0) scale(1); }
    50% { transform: translate(40px, 30px) scale(1.08); }
  }
  @keyframes mxFloatB {
    0%, 100% { transform: translate(0, 0) scale(1); }
    50% { transform: translate(-30px, -40px) scale(1.1); }
  }

  /* ─── Trust band ─────────────────────────────────────────────────────── */
  .mx-trust {
    padding: 32px 0 16px 0;
  }
  .mx-trust-inner {
    text-align: center;
    max-width: 780px;
  }
  .mx-trust-title {
    font-family: var(--mx-font-display);
    font-size: clamp(1.2rem, 2vw, 1.55rem);
    font-weight: 600;
    color: var(--mx-text-2);
    margin: 0 0 8px 0;
    line-height: 1.4;
    letter-spacing: -0.4px;
  }
  .mx-trust-sub {
    font-family: var(--mx-font-mono);
    font-size: 0.82rem;
    letter-spacing: 2.4px;
    text-transform: uppercase;
    color: var(--mx-gold);
    margin: 0;
  }

  /* ─── Features grid ──────────────────────────────────────────────────── */
  .mx-features-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }
  .mx-feature {
    padding: 32px 28px;
    transition: transform 0.22s ease, border-color 0.22s ease;
  }
  .mx-feature:hover {
    transform: translateY(-3px);
    border-color: rgba(168, 85, 247, 0.3);
  }
  .mx-feature-icon {
    width: 48px;
    height: 48px;
    border-radius: 14px;
    background: rgba(168, 85, 247, 0.08);
    border: 1px solid var(--mx-border-strong);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--mx-gold);
    margin-bottom: 20px;
  }
  .mx-feature-icon svg { width: 24px; height: 24px; }
  .mx-feature-title {
    font-family: var(--mx-font-display);
    font-size: 1.18rem;
    font-weight: 600;
    color: var(--mx-text);
    margin: 0 0 10px 0;
    letter-spacing: -0.3px;
  }
  .mx-feature-desc {
    font-family: var(--mx-font-body);
    font-size: 0.95rem;
    color: var(--mx-text-muted);
    line-height: 1.6;
    margin: 0;
  }
  @media (max-width: 900px) {
    .mx-features-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 560px) {
    .mx-features-grid { grid-template-columns: 1fr; }
  }

  /* ─── How it works ───────────────────────────────────────────────────── */
  .mx-steps-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }
  .mx-step {
    position: relative;
    padding: 32px 28px;
  }
  .mx-step-label {
    font-family: var(--mx-font-mono);
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 2.2px;
    text-transform: uppercase;
    color: var(--mx-gold);
    display: block;
    margin-bottom: 14px;
  }
  .mx-step-title {
    font-family: var(--mx-font-display);
    font-size: 1.35rem;
    font-weight: 600;
    color: var(--mx-text);
    margin: 0 0 12px 0;
    letter-spacing: -0.4px;
  }
  .mx-step-desc {
    font-family: var(--mx-font-body);
    font-size: 0.95rem;
    color: var(--mx-text-muted);
    line-height: 1.6;
    margin: 0;
  }
  .mx-step-arrow {
    position: absolute;
    top: 50%;
    right: -16px;
    transform: translateY(-50%);
    font-size: 1.6rem;
    color: var(--mx-purple-2);
    opacity: 0.6;
    z-index: 2;
  }
  @media (max-width: 900px) {
    .mx-steps-grid { grid-template-columns: 1fr; }
    .mx-step-arrow { display: none; }
  }

  /* ─── Metrics ────────────────────────────────────────────────────────── */
  .mx-metrics-title {
    margin-bottom: 48px;
  }
  .mx-metrics-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 18px;
  }
  .mx-metric {
    padding: 24px 22px;
    border-radius: var(--mx-radius);
    border: 1px solid var(--mx-border-strong);
    background: rgba(168, 85, 247, 0.04);
  }
  .mx-metric-label {
    display: block;
    font-family: var(--mx-font-display);
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--mx-gold);
    margin-bottom: 8px;
    letter-spacing: -0.2px;
  }
  .mx-metric-desc {
    font-family: var(--mx-font-body);
    font-size: 0.88rem;
    color: var(--mx-text-muted);
    margin: 0;
    line-height: 1.5;
  }
  @media (max-width: 900px) {
    .mx-metrics-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 480px) {
    .mx-metrics-grid { grid-template-columns: 1fr; }
  }

  /* ─── Pricing ────────────────────────────────────────────────────────── */
  .mx-billing-toggle {
    display: inline-flex;
    margin: 0 auto 40px auto;
    padding: 4px;
    background: rgba(168, 85, 247, 0.06);
    border: 1px solid var(--mx-border-strong);
    border-radius: 999px;
    justify-content: center;
  }
  .mx-section .mx-billing-toggle {
    display: flex;
    width: fit-content;
    margin-left: auto;
    margin-right: auto;
  }
  .mx-billing-btn {
    min-height: 40px;
    padding: 8px 22px;
    background: transparent;
    border: none;
    border-radius: 999px;
    font-family: var(--mx-font-body);
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--mx-text-muted);
    cursor: pointer;
    transition: background 0.18s ease, color 0.18s ease;
  }
  .mx-billing-btn.mx-billing-active {
    background: linear-gradient(135deg, #fbbf24 0%, #f59e0b 100%);
    color: #1a0f00;
    font-weight: 600;
  }

  .mx-pricing-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
    max-width: 880px;
    margin: 0 auto;
  }
  .mx-price-card {
    position: relative;
    padding: 36px 32px;
    display: flex;
    flex-direction: column;
  }
  .mx-price-card-featured {
    border-color: var(--mx-border-gold);
    box-shadow:
      0 1px 0 rgba(255, 255, 255, 0.04) inset,
      0 8px 32px rgba(0, 0, 0, 0.45),
