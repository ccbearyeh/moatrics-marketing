  /* ── Hero slider ────────────────────────────────────────────────────────
     CSS grid stacking: both slides occupy the same grid cell, fade in/out
     via opacity. min-height keeps the section stable so neighboring
     content doesn't reflow during transitions. */
  .mx-hero-slider {
    position: relative;
    z-index: 2;
    display: grid;
    grid-template-areas: 'stack';
    grid-template-columns: 1fr;
    width: 100%;
    min-height: 600px;
    padding-bottom: 56px; /* room for dot nav */
  }
  .mx-hero-slide {
    grid-area: stack;
    opacity: 0;
    visibility: hidden;
    transform: translateY(8px);
    transition:
      opacity 600ms ease,
      transform 600ms ease,
      visibility 0s linear 600ms;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
  }
  .mx-hero-slide-active {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
    transition:
      opacity 600ms ease,
      transform 600ms ease,
      visibility 0s linear 0s;
  }
  .mx-hero-preview-wrap {
    width: 100%;
    text-align: center;
  }
  .mx-hero-preview-head {
    margin-bottom: 28px;
  }
  .mx-hero-preview-head .mx-section-title {
    font-size: clamp(1.6rem, 3.2vw, 2.2rem);
  }

  /* ── Dot navigation ─────────────────────────────────────────────────── */
  .mx-hero-dots {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 14px;
    display: flex;
    justify-content: center;
    gap: 10px;
    z-index: 3;
  }
  .mx-hero-dot {
    width: 10px;
    height: 10px;
    padding: 0;
    border-radius: 999px;
    border: 1px solid var(--mx-border-strong);
    background: rgba(168, 85, 247, 0.18);
    cursor: pointer;
    transition: width 0.3s ease, background 0.25s ease, border-color 0.25s ease;
  }
  .mx-hero-dot:hover {
    border-color: rgba(251, 191, 36, 0.55);
    background: rgba(251, 191, 36, 0.25);
  }
  .mx-hero-dot:focus-visible {
    outline: 2px solid var(--mx-gold);
    outline-offset: 2px;
  }
  .mx-hero-dot-active {
    width: 28px;
    background: linear-gradient(135deg, #fbbf24 0%, #f59e0b 100%);
    border-color: rgba(251, 191, 36, 0.6);
