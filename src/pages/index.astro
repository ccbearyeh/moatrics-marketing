---
/**
 * Moatrics homepage — Phase B redesign.
 *
 * Sections (top → bottom):
 *   1. Hero — animated gradient blobs, KPI chip strip, trust line
 *   2. "Why Moatrics" — 3 trust cards (focus / discipline / transparency)
 *   3. Features — Bento grid (2 hero + 3 medium + 1 wide)
 *   4. How It Works — 3 steps with SVG connecting line
 *   5. Metrics band — giant display numbers
 *   6. Product preview — dark glass mock screenshot
 *   7. Pricing teaser — Free / Pro toggle (vanilla JS)
 *   8. FAQ — pure CSS <details>/<summary> accordion
 *   9. CTA banner
 *
 * All visible copy dual-renders EN+ZH inline via <T>. Links go to /get-access
 * (the no-backend invite form) — never directly to app.moatrics.com/signup.
 */
import PublicLayout from '../layouts/PublicLayout.astro';
import T from '../components/T.astro';
import { t, getNode } from '../i18n';

// Used only for "Sign In" deep-link (existing accounts go to the app).
const APP_BASE = 'https://app.moatrics.com';

const trustKeys = ['focus', 'discipline', 'transparency'] as const;
const stepKeys = ['screen', 'analyze', 'decide'] as const;
const metricKeys = ['roic', 'debt', 'growth', 'valuation'] as const;
const faqKeys = ['what_is', 'who_for', 'advice', 'data', 'invite', 'cancel'] as const;

// Bento layout: each card carries its own size hint so we can drive a 12-col
// grid with the same loop. Keep this list ordered top-to-bottom, left-to-right.
const featureLayout = [
  { k: 'moat',      size: 'lg' },   // hero
  { k: 'valuation', size: 'md' },   // hero secondary
  { k: 'screener',  size: 'sm' },
  { k: 'watchlist', size: 'sm' },
  { k: 'gurus',     size: 'sm' },
  { k: 'journal',   size: 'wide' }, // full-width footer card
] as const;

// Pricing feature lists — fetched per-language so we can dual-render each item
// (CSS hides the language sibling that doesn't match `<html lang>`).
const freeFeaturesEn = (getNode('home.pricing_teaser.free.features', 'en') as string[]) ?? [];
const freeFeaturesZh = (getNode('home.pricing_teaser.free.features', 'zh') as string[]) ?? [];
const proFeaturesEn = (getNode('home.pricing_teaser.pro.features', 'en') as string[]) ?? [];
const proFeaturesZh = (getNode('home.pricing_teaser.pro.features', 'zh') as string[]) ?? [];

const freeFeaturePairs = freeFeaturesEn.map((en, i) => [en, freeFeaturesZh[i] ?? en] as const);
const proFeaturePairs = proFeaturesEn.map((en, i) => [en, proFeaturesZh[i] ?? en] as const);

// Pricing toggle values pre-resolved in both languages — used as data-* on the
// dual-render siblings so the vanilla JS billing switcher swaps textContent
// inside whichever language sibling is currently visible.
const proPriceMonthlyEn = t('home.pricing_teaser.pro.price_monthly', 'en');
const proPriceMonthlyZh = t('home.pricing_teaser.pro.price_monthly', 'zh');
const proPriceAnnuallyEn = t('home.pricing_teaser.pro.price_annually', 'en');
const proPriceAnnuallyZh = t('home.pricing_teaser.pro.price_annually', 'zh');
const proNoteMonthlyEn = t('home.pricing_teaser.pro.billing_note_monthly', 'en');
const proNoteMonthlyZh = t('home.pricing_teaser.pro.billing_note_monthly', 'zh');
const proNoteAnnuallyEn = t('home.pricing_teaser.pro.billing_note_annually', 'en');
const proNoteAnnuallyZh = t('home.pricing_teaser.pro.billing_note_annually', 'zh');

const title = 'Moatrics — Invest in Quality Companies. Undervalued.';
const description =
  'Moatrics is a data-driven co-pilot for long-term, value-conscious investors. Quality businesses, durable moats, margin of safety.';
---

<PublicLayout title={title} description={description} path="/">
  {/* ─── 1. HERO — 2-slide cross-fade slider ─────────────────────────────
       Slide A: classic value-prop (eyebrow + title + subtitle + trust + CTAs)
       Slide B: in-app preview mock (used to live in its own section).
       Auto-rotates every 7s, pauses on hover / when tab hidden / on dot click.
       Honors prefers-reduced-motion: no auto-advance, no transitions. */}
  <section class="mx-hero" id="hero">
    <div class="mx-hero-blob mx-hero-blob-a" aria-hidden="true"></div>
    <div class="mx-hero-blob mx-hero-blob-b" aria-hidden="true"></div>

    <div class="mx-hero-slider" data-hero-slider aria-roledescription="carousel" aria-label="Moatrics overview">

      {/* ── Slide A: pitch ───────────────────────────────────────── */}
      <div
        class="mx-hero-slide mx-hero-slide-active"
        data-slide="0"
        role="group"
        aria-roledescription="slide"
        aria-label="1 of 2 — Invest in quality"
        aria-hidden="false"
      >
        <div class="mx-container mx-hero-inner">
          <T k="home.hero.eyebrow" as="span" class="mx-eyebrow" data-reveal />
          <T k="home.hero.title" as="h1" class="mx-hero-title" data-reveal data-reveal-delay="1" />
          <T k="home.hero.subtitle" as="p" class="mx-hero-subtitle" data-reveal data-reveal-delay="2" />
          <T k="home.hero.trust_line" as="p" class="mx-hero-trust" data-reveal data-reveal-delay="2" />

          <div class="mx-hero-cta" data-reveal data-reveal-delay="3">
            <a class="mx-btn mx-btn-primary" href="/get-access">
              <T k="home.hero.cta_primary" />
            </a>
            <a class="mx-btn mx-btn-secondary" href="#how-it-works">
              <T k="home.hero.cta_secondary" />
            </a>
          </div>
        </div>
      </div>

      {/* ── Slide B: in-app preview ──────────────────────────────── */}
      <div
        class="mx-hero-slide"
        data-slide="1"
        role="group"
        aria-roledescription="slide"
        aria-label="2 of 2 — Inside Moatrics"
        aria-hidden="true"
      >
        <div class="mx-container mx-hero-preview-wrap">
          <div class="mx-section-head mx-hero-preview-head">
            <T k="home.preview.section_eyebrow" as="span" class="mx-eyebrow" />
            <T k="home.preview.section_title" as="h2" class="mx-section-title" />
            <T k="home.preview.section_subtitle" as="p" class="mx-section-sub" />
          </div>

          <div class="mx-preview-frame mx-glass">
            <header class="mx-preview-chrome" aria-hidden="true">
              <span class="mx-preview-dot" style="background:#ef4444"></span>
              <span class="mx-preview-dot" style="background:#fbbf24"></span>
              <span class="mx-preview-dot" style="background:#22c55e"></span>
              <span class="mx-preview-url">moatrics.com / app / stock-analysis</span>
            </header>

            <div class="mx-preview-body">
              <aside class="mx-preview-sidebar" aria-hidden="true">
                <span class="mx-preview-side-row mx-preview-side-active">Stock Analysis</span>
                <span class="mx-preview-side-row">Screener</span>
                <span class="mx-preview-side-row">Watchlist</span>
                <span class="mx-preview-side-row">Journal</span>
              </aside>

              <main class="mx-preview-main">
                <div class="mx-preview-row mx-preview-row-head">
                  <div>
                    <p class="mx-preview-ticker">COST · Costco Wholesale</p>
                    <T k="home.preview.caption_subtitle" as="p" class="mx-preview-caption" />
                  </div>
                  <span class="mx-preview-pill">ON SALE</span>
                </div>

                <div class="mx-preview-stats">
                  <div class="mx-preview-stat">
                    <span class="mx-preview-stat-label">ROIC</span>
                    <span class="mx-preview-stat-value mx-preview-stat-pass">22.4%</span>
                  </div>
                  <div class="mx-preview-stat">
                    <span class="mx-preview-stat-label">Debt / Earnings</span>
                    <span class="mx-preview-stat-value mx-preview-stat-pass">1.2 yr</span>
                  </div>
                  <div class="mx-preview-stat">
                    <span class="mx-preview-stat-label">EPS CAGR (10y)</span>
                    <span class="mx-preview-stat-value mx-preview-stat-pass">14.8%</span>
                  </div>
                  <div class="mx-preview-stat">
                    <span class="mx-preview-stat-label">Margin of Safety</span>
                    <span class="mx-preview-stat-value mx-preview-stat-pass">58%</span>
                  </div>
                </div>

                <svg class="mx-preview-chart" viewBox="0 0 500 110" preserveAspectRatio="none" aria-hidden="true">
                  <defs>
                    <linearGradient id="mxPvFill" x1="0" x2="0" y1="0" y2="1">
                      <stop offset="0%" stop-color="#a855f7" stop-opacity="0.45" />
                      <stop offset="100%" stop-color="#a855f7" stop-opacity="0" />
                    </linearGradient>
                  </defs>
                  <path
                    d="M 0 80 L 50 70 L 100 75 L 150 55 L 200 60 L 250 45 L 300 50 L 350 30 L 400 35 L 450 18 L 500 22"
                    fill="none"
                    stroke="#fbbf24"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  />
                  <path
                    d="M 0 80 L 50 70 L 100 75 L 150 55 L 200 60 L 250 45 L 300 50 L 350 30 L 400 35 L 450 18 L 500 22 L 500 110 L 0 110 Z"
                    fill="url(#mxPvFill)"
                  />
                </svg>
              </main>
            </div>
          </div>
        </div>
      </div>

      {/* ── Dot navigation ───────────────────────────────────────── */}
      <div class="mx-hero-dots" role="tablist" aria-label="Slide navigation">
        <button
          type="button"
          class="mx-hero-dot mx-hero-dot-active"
          data-dot="0"
          role="tab"
          aria-selected="true"
          aria-label="Show slide 1: Invest in quality"
        ></button>
        <button
          type="button"
          class="mx-hero-dot"
          data-dot="1"
          role="tab"
          aria-selected="false"
          aria-label="Show slide 2: Inside Moatrics"
        ></button>
      </div>
    </div>
  </section>

  <div class="mx-divider" aria-hidden="true"></div>

  {/* ─── 2. WHY MOATRICS (TRUST CARDS) ──────────────────────────────────── */}
  <section class="mx-section-tight mx-section-band" id="why">
    <div class="mx-container">
      <div class="mx-section-head" data-reveal>
        <T k="home.trust.eyebrow" as="span" class="mx-eyebrow" />
        <T k="home.trust.title" as="h2" class="mx-section-title" />
        <T k="home.trust.subtitle" as="p" class="mx-section-sub" />
      </div>

      <div class="mx-trust-grid">
        {trustKeys.map((k, i) => (
          <article
            class="mx-trust-card mx-glass"
            data-reveal
            data-reveal-delay={String((i % 3) + 1)}
          >
            <span class="mx-trust-index" aria-hidden="true">
              {String(i + 1).padStart(2, '0')}
            </span>
            <T k={`home.trust.cards.${k}.title`} as="h3" class="mx-trust-card-title" />
            <T k={`home.trust.cards.${k}.desc`} as="p" class="mx-trust-card-desc" />
          </article>
        ))}
      </div>
    </div>
  </section>

  {/* ─── 3. FEATURES — BENTO GRID ────────────────────────────────────────── */}
  <section class="mx-section" id="features">
    <div class="mx-container">
      <div class="mx-section-head" data-reveal>
        <T k="home.features.section_eyebrow" as="span" class="mx-eyebrow mx-eyebrow-purple" />
        <T k="home.features.section_title" as="h2" class="mx-section-title" />
        <T k="home.features.section_subtitle" as="p" class="mx-section-sub" />
      </div>

      <div class="mx-bento">
        {featureLayout.map(({ k, size }, i) => (
          <article
            class={`mx-feature mx-glass mx-feature-${size}`}
            data-reveal
            data-reveal-delay={String((i % 3) + 1)}
          >
            <div class="mx-feature-icon" aria-hidden="true">
              {k === 'moat' && (
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M3 21V10l9-7 9 7v11" />
                  <path d="M9 21v-6h6v6" />
                  <path d="M3 14h18" />
                </svg>
              )}
              {k === 'valuation' && (
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M12 3v18" />
                  <path d="M5 8h14" />
                  <path d="M5 8l-2 6a4 4 0 0 0 8 0L9 8" />
                  <path d="M19 8l-2 6a4 4 0 0 0 8 0l-2-6" />
                </svg>
              )}
              {k === 'screener' && (
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M3 5h18l-7 8v6l-4-2v-4z" />
                </svg>
              )}
              {k === 'watchlist' && (
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                  <circle cx="12" cy="12" r="3" />
                  <path d="M2 12s3.5-7 10-7 10 7 10 7-3.5 7-10 7S2 12 2 12z" />
                </svg>
              )}
              {k === 'gurus' && (
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                  <circle cx="9" cy="8" r="4" />
                  <path d="M2 21v-2a5 5 0 0 1 5-5h4a5 5 0 0 1 5 5v2" />
                  <circle cx="17" cy="6" r="3" />
                  <path d="M22 21v-1a4 4 0 0 0-3-3.9" />
                </svg>
              )}
              {k === 'journal' && (
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M4 4h13a3 3 0 0 1 3 3v13a0 0 0 0 1 0 0H7a3 3 0 0 1-3-3z" />
                  <path d="M4 4v13a3 3 0 0 0 3 3" />
                  <path d="M8 8h8M8 12h8M8 16h5" />
                </svg>
              )}
            </div>
            <T k={`home.features.items.${k}.title`} as="h3" class="mx-feature-title" />
            <T k={`home.features.items.${k}.desc`} as="p" class="mx-feature-desc" />
          </article>
        ))}
      </div>
    </div>
  </section>

  <div class="mx-divider" aria-hidden="true"></div>

  {/* ─── 4. HOW IT WORKS ─────────────────────────────────────────────────── */}
  <section class="mx-section mx-section-band" id="how-it-works">
    <div class="mx-container">
      <div class="mx-section-head" data-reveal>
        <T k="home.how_it_works.section_eyebrow" as="span" class="mx-eyebrow" />
        <T k="home.how_it_works.section_title" as="h2" class="mx-section-title" />
        <T k="home.how_it_works.section_subtitle" as="p" class="mx-section-sub" />
      </div>

      <div class="mx-steps-wrap">
        {/* SVG connecting line — drawn under the cards on desktop only. */}
        <svg
          class="mx-steps-line"
          viewBox="0 0 1000 80"
          preserveAspectRatio="none"
          aria-hidden="true"
        >
          <defs>
            <linearGradient id="mxStepsGrad" x1="0" x2="1" y1="0" y2="0">
              <stop offset="0%"  stop-color="#a855f7" stop-opacity="0.0" />
              <stop offset="15%" stop-color="#a855f7" stop-opacity="0.55" />
              <stop offset="50%" stop-color="#fbbf24" stop-opacity="0.6" />
              <stop offset="85%" stop-color="#a855f7" stop-opacity="0.55" />
              <stop offset="100%" stop-color="#a855f7" stop-opacity="0.0" />
            </linearGradient>
          </defs>
          <path
            d="M 30 40 C 250 -10, 400 90, 500 40 S 750 -10, 970 40"
            stroke="url(#mxStepsGrad)"
            stroke-width="1.5"
            fill="none"
            stroke-dasharray="5 6"
          />
        </svg>

        <div class="mx-steps-grid">
          {stepKeys.map((k, i) => (
            <article
              class="mx-step mx-glass"
              data-reveal
              data-reveal-delay={String((i % 3) + 1)}
            >
              <span class="mx-step-num" aria-hidden="true">
                {String(i + 1).padStart(2, '0')}
              </span>
              <T k={`home.how_it_works.steps.${k}.label`} as="span" class="mx-step-label" />
              <T k={`home.how_it_works.steps.${k}.title`} as="h3" class="mx-step-title" />
              <T k={`home.how_it_works.steps.${k}.desc`} as="p" class="mx-step-desc" />
            </article>
          ))}
        </div>
      </div>
    </div>
  </section>

  {/* ─── 5. METRICS BAND — GIANT NUMBERS ─────────────────────────────────── */}
  <section class="mx-section-tight">
    <div class="mx-container">
      <T k="home.metrics.section_title" as="h2" class="mx-section-title mx-metrics-title" data-reveal />
      <div class="mx-metrics-grid">
        <div class="mx-metric" data-reveal data-reveal-delay="1">
          <span class="mx-metric-big">10%<span class="mx-metric-big-suffix">+</span></span>
          <T k="home.metrics.items.roic.label" as="span" class="mx-metric-label" />
          <T k="home.metrics.items.roic.desc" as="p" class="mx-metric-desc" />
        </div>
        <div class="mx-metric" data-reveal data-reveal-delay="2">
          <span class="mx-metric-big">3<span class="mx-metric-big-suffix">yr</span></span>
          <T k="home.metrics.items.debt.label" as="span" class="mx-metric-label" />
          <T k="home.metrics.items.debt.desc" as="p" class="mx-metric-desc" />
        </div>
        <div class="mx-metric" data-reveal data-reveal-delay="3">
          <span class="mx-metric-big">10<span class="mx-metric-big-suffix">yr</span></span>
          <T k="home.metrics.items.growth.label" as="span" class="mx-metric-label" />
          <T k="home.metrics.items.growth.desc" as="p" class="mx-metric-desc" />
        </div>
        <div class="mx-metric" data-reveal data-reveal-delay="3">
          <span class="mx-metric-big">50%<span class="mx-metric-big-suffix">+</span></span>
          <T k="home.metrics.items.valuation.label" as="span" class="mx-metric-label" />
          <T k="home.metrics.items.valuation.desc" as="p" class="mx-metric-desc" />
        </div>
      </div>
    </div>
  </section>

  {/* ─── 6. PRODUCT PREVIEW ─── moved into the hero slider (slide B). ────── */}

  {/* ─── 7. PRICING TEASER ───────────────────────────────────────────────── */}
  <section class="mx-section mx-section-band" id="pricing">
    <div class="mx-container">
      <div class="mx-section-head" data-reveal>
        <T k="home.pricing_teaser.section_eyebrow" as="span" class="mx-eyebrow" />
        <T k="home.pricing_teaser.section_title" as="h2" class="mx-section-title" />
        <T k="home.pricing_teaser.section_subtitle" as="p" class="mx-section-sub" />
      </div>

      <div class="mx-billing-toggle" role="tablist" aria-label="Billing cycle" data-reveal>
        <button
          type="button"
          role="tab"
          aria-selected="true"
          class="mx-billing-btn mx-billing-active"
          data-billing="monthly"
        >
          <T k="home.pricing_teaser.billing_monthly" />
        </button>
        <button
          type="button"
          role="tab"
          aria-selected="false"
          class="mx-billing-btn"
          data-billing="annually"
        >
          <T k="home.pricing_teaser.billing_annually" />
        </button>
      </div>

      <div class="mx-pricing-grid">
        {/* Free */}
        <article class="mx-price-card mx-glass" data-reveal data-reveal-delay="1">
          <header class="mx-price-head">
            <T k="home.pricing_teaser.free.name" as="h3" class="mx-price-name" />
            <div class="mx-price-amount">
              <T k="home.pricing_teaser.free.price" as="span" class="mx-price-num" />
              <T k="home.pricing_teaser.free.period" as="span" class="mx-price-period" />
            </div>
            <T k="home.pricing_teaser.free.tagline" as="p" class="mx-price-tag" />
          </header>
          <ul role="list" class="mx-price-list">
            {freeFeaturePairs.map(([en, zh]) => (
              <li>
                <span class="mx-price-check" aria-hidden="true">✓</span>
                <span class="mx-i18n" lang="en" data-i18n-lang="en">{en}</span>
                <span class="mx-i18n" lang="zh" data-i18n-lang="zh">{zh}</span>
              </li>
            ))}
          </ul>
          <a class="mx-btn mx-btn-secondary mx-price-cta" href="/get-access">
            <T k="home.pricing_teaser.free.cta" />
          </a>
        </article>

        {/* Pro */}
        <article class="mx-price-card mx-price-card-featured mx-glass" data-reveal data-reveal-delay="2">
          <span class="mx-price-badge">
            <T k="home.pricing_teaser.recommended_badge" />
          </span>
          <header class="mx-price-head">
            <T k="home.pricing_teaser.pro.name" as="h3" class="mx-price-name" />
            <div class="mx-price-amount">
              <span
                class="mx-price-num mx-i18n"
                lang="en"
                data-i18n-lang="en"
                data-monthly={proPriceMonthlyEn}
                data-annually={proPriceAnnuallyEn}
              >{proPriceMonthlyEn}</span>
              <span
                class="mx-price-num mx-i18n"
                lang="zh"
                data-i18n-lang="zh"
                data-monthly={proPriceMonthlyZh}
                data-annually={proPriceAnnuallyZh}
              >{proPriceMonthlyZh}</span>
              <T k="home.pricing_teaser.pro.period" as="span" class="mx-price-period" />
            </div>
            <p
              class="mx-price-tag mx-i18n"
              lang="en"
              data-i18n-lang="en"
              data-monthly={proNoteMonthlyEn}
              data-annually={proNoteAnnuallyEn}
            >{proNoteMonthlyEn}</p>
            <p
              class="mx-price-tag mx-i18n"
              lang="zh"
              data-i18n-lang="zh"
              data-monthly={proNoteMonthlyZh}
              data-annually={proNoteAnnuallyZh}
            >{proNoteMonthlyZh}</p>
            <T k="home.pricing_teaser.pro.tagline" as="p" class="mx-price-tag" />
          </header>
          <ul role="list" class="mx-price-list">
            {proFeaturePairs.map(([en, zh]) => (
              <li>
                <span class="mx-price-check" aria-hidden="true">✓</span>
                <span class="mx-i18n" lang="en" data-i18n-lang="en">{en}</span>
                <span class="mx-i18n" lang="zh" data-i18n-lang="zh">{zh}</span>
              </li>
            ))}
          </ul>
          <a class="mx-btn mx-btn-primary mx-price-cta" href="/get-access">
            <T k="home.pricing_teaser.pro.cta" />
          </a>
        </article>
      </div>
    </div>
  </section>

  <div class="mx-divider" aria-hidden="true"></div>

  {/* ─── 8. FAQ ──────────────────────────────────────────────────────────── */}
  <section class="mx-section" id="faq">
    <div class="mx-container">
      <div class="mx-section-head" data-reveal>
        <T k="home.faq.section_eyebrow" as="span" class="mx-eyebrow" />
        <T k="home.faq.section_title" as="h2" class="mx-section-title" />
