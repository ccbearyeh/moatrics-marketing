---
/**
 * Site-wide footer.
 *
 * Four-column grid on desktop (brand+disclaimer / product / company / legal),
 * collapses to a single column < 768px. Real `<a>` tags only — no JS.
 *
 * Contact email is ALWAYS service@moatrics.com — see CLAUDE.md
 * "Contact email policy" before introducing any other address.
 *
 * All visible copy goes through `<T>` so it dual-renders EN + ZH inline and
 * CSS swaps visibility based on `<html lang>` (set by the navbar toggle).
 */
import T from './T.astro';

const APP_BASE = 'https://app.moatrics.com';
const CONTACT_EMAIL = 'service@moatrics.com';

// Each entry pairs an href with the dotted-path translation key.
// <T k={l.k} /> renders both EN + ZH copies inline; the CSS in global.css
// hides the inactive language version on the fly.
// Keep in sync with Navbar.astro `navLinks`. The footer Product column mirrors
// the on-page anchors in the top nav; Sign In is appended below.
const productLinks = [
  { href: '/#features',     k: 'footer.links.features' },
  { href: '/#how-it-works', k: 'footer.links.how_it_works' },
  { href: '/#pricing',      k: 'footer.links.pricing' },
  { href: '/#faq',          k: 'footer.links.faq' },
];

const companyLinks = [
  { href: `mailto:${CONTACT_EMAIL}`, k: 'footer.links.contact' },
];

const legalLinks = [
  { href: '/terms',      k: 'footer.links.terms' },
  { href: '/privacy',    k: 'footer.links.privacy' },
  { href: '/disclaimer', k: 'footer.links.disclaimer' },
];
---

<footer class="mx-footer">
  <div class="mx-container">
    <div class="mx-footer-grid">
      <div class="mx-footer-brand">
        <a href="/" class="mx-footer-logo" aria-label="Moatrics — home">
          <img
            src="/moatrics-logo.png"
            alt=""
            width="42"
            height="42"
            class="mx-footer-logo-img"
            loading="lazy"
            decoding="async"
          />
          <span class="mx-footer-logo-text">Moatrics</span>
        </a>
        <T k="footer.tagline" as="p" class="mx-footer-tagline" />
        <T k="footer.disclaimer_short" as="p" class="mx-footer-disclaimer" />
      </div>

      <div class="mx-footer-col">
        <T k="footer.sections.product" as="h3" class="mx-footer-col-title" />
        <ul role="list" class="mx-footer-list">
          {productLinks.map((l) => (
            <li><a href={l.href}><T k={l.k} /></a></li>
          ))}
          <li>
            <a href={`${APP_BASE}/signin`}><T k="nav.signin" /></a>
          </li>
        </ul>
      </div>

      <div class="mx-footer-col">
        <T k="footer.sections.company" as="h3" class="mx-footer-col-title" />
        <ul role="list" class="mx-footer-list">
          {companyLinks.map((l) => (
            <li><a href={l.href}><T k={l.k} /></a></li>
          ))}
        </ul>
      </div>

      <div class="mx-footer-col">
        <T k="footer.sections.legal" as="h3" class="mx-footer-col-title" />
        <ul role="list" class="mx-footer-list">
          {legalLinks.map((l) => (
            <li><a href={l.href}><T k={l.k} /></a></li>
          ))}
        </ul>
      </div>
    </div>

    <div class="mx-footer-bottom">
      <T k="footer.copyright" as="p" class="mx-footer-copyright" />
      <T k="footer.made_with" as="p" class="mx-footer-made" />
    </div>
  </div>
</footer>

<style>
  .mx-footer {
    margin-top: 64px;
    padding: 80px 0 40px 0;
    border-top: 1px solid var(--mx-border);
    background:
      linear-gradient(to bottom, transparent 0%, rgba(13, 7, 25, 0.6) 100%);
  }

  .mx-footer-grid {
    display: grid;
    grid-template-columns: 1.6fr 1fr 1fr 1fr;
    gap: 56px;
    margin-bottom: 56px;
  }

  .mx-footer-brand { max-width: 420px; }
  .mx-footer-logo {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 14px;
  }
  .mx-footer-logo-img {
    height: 42px;
    width: auto;
    display: block;
    filter: drop-shadow(0 0 12px rgba(168, 85, 247, 0.22));
  }
  .mx-footer-logo-text {
    font-family: var(--mx-font-display);
    font-size: 1.35rem;
    font-weight: 700;
    background: linear-gradient(135deg, #c084fc 0%, #a855f7 35%, #fbbf24 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    letter-spacing: -0.4px;
  }
  .mx-footer-tagline {
    font-family: var(--mx-font-body);
    font-size: 0.95rem;
    color: var(--mx-text-2);
    margin: 0 0 14px 0;
  }
  .mx-footer-disclaimer {
    font-family: var(--mx-font-body);
    font-size: 0.82rem;
    color: var(--mx-text-muted);
    line-height: 1.55;
    margin: 0;
  }

  /* :global() because <T as="h3"> renders outside this component's scope.
     Without it the headings inherit body styles and look identical to links. */
  :global(.mx-footer-col-title) {
    font-family: var(--mx-font-mono);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 2.4px;
    text-transform: uppercase;
    color: var(--mx-gold);
    margin: 0 0 20px 0;
    opacity: 0.85;
  }
  .mx-footer-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .mx-footer-list a {
    font-family: var(--mx-font-body);
    font-size: 0.92rem;
    color: var(--mx-text-2);
    transition: color 0.18s ease;
    display: inline-block;
    min-height: 24px;
  }
  .mx-footer-list a:hover { color: var(--mx-gold); }

  .mx-footer-bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: 28px;
    border-top: 1px solid var(--mx-border);
    gap: 20px;
    flex-wrap: wrap;
  }
  .mx-footer-copyright,
  .mx-footer-made {
    margin: 0;
    font-family: var(--mx-font-body);
    font-size: 0.82rem;
    color: var(--mx-text-muted);
  }

  @media (max-width: 900px) {
    .mx-footer-grid {
      grid-template-columns: 1fr 1fr;
      gap: 40px;
    }
    .mx-footer-brand {
      grid-column: 1 / -1;
      max-width: none;
    }
  }
  @media (max-width: 560px) {
    .mx-footer {
      padding: 56px 0 32px 0;
    }
    .mx-footer-grid {
      grid-template-columns: 1fr;
      gap: 36px;
    }
    .mx-footer-bottom {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>
