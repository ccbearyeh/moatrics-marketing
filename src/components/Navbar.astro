---
/**
 * Sticky pill-shaped glass navbar with gold gradient wordmark.
 *
 * Layout (desktop, left → right):
 *   [Brand]  [Features · How It Works · Pricing · Contact]  [EN/中  Sign In  Get Access]
 *
 * - Contact = mailto:service@moatrics.com — the only contact email for this
 *   project. See CLAUDE.md "Contact email policy" before adding any other.
 * - EN/中 toggle writes `moatrics_lang` cookie + updates <html lang>.
 *   The inline script in PublicLayout.astro reads that cookie BEFORE first
 *   paint so the CSS dual-render in `<T>` shows the right copy with zero
 *   flash. URLs stay the same regardless of language.
 * - Auth links go to `app.moatrics.com` — the Streamlit app subdomain.
 * - Below 768px we collapse to a hamburger drawer; the drawer carries the
 *   same toggle so mobile users can switch language too.
 */
import { t } from '../i18n';
import T from './T.astro';

const APP_BASE = 'https://app.moatrics.com';
const CONTACT_EMAIL = 'service@moatrics.com';

// Nav links — keys are dotted paths into i18n/en.json + zh.json.
// `<T>` renders both languages inline; CSS hides the inactive one.
const navLinks = [
  { href: '/#features',      k: 'nav.features' },
  { href: '/#how-it-works',  k: 'nav.how_it_works' },
  { href: '/#pricing',       k: 'nav.pricing' },
  { href: '/#faq',           k: 'nav.faq' },
  { href: `mailto:${CONTACT_EMAIL}`, k: 'nav.contact' },
];
---

<header class="mx-navbar-wrap" id="mx-navbar-wrap">
  <div class="mx-container">
    <nav class="mx-navbar" aria-label="Primary">
      <a href="/" class="mx-brand" aria-label="Moatrics — home">
        <img
          src="/moatrics-logo.png"
          alt=""
          width="44"
          height="44"
          class="mx-logo"
          loading="eager"
          decoding="async"
        />
        <span class="mx-logo-text">Moatrics</span>
      </a>

      <ul class="mx-nav-links" role="list">
        {navLinks.map((l) => (
          <li><a href={l.href}><T k={l.k} /></a></li>
        ))}
      </ul>

      <div class="mx-nav-cta">
        {/* EN/中 segmented pill — wired by inline script at end of file */}
        <div
          class="mx-lang-toggle"
          role="group"
          aria-label="Language / 語言"
          data-mx-lang-group
        >
          <button
            type="button"
            class="mx-lang-toggle__btn"
            data-mx-lang="en"
            aria-pressed="true"
          >EN</button>
          <button
            type="button"
            class="mx-lang-toggle__btn"
            data-mx-lang="zh"
            aria-pressed="false"
          >中</button>
        </div>

        {/* App root, not /signin — signin is Streamlit's default page (served at /),
            so linking to / avoids the transient "Page not found" toast + URL rewrite to /. */}
        <a class="mx-btn mx-btn-secondary mx-nav-signin" href={`${APP_BASE}/`}>
          <T k="nav.signin" />
        </a>
        <a class="mx-btn mx-btn-primary" href="/get-access">
          <T k="nav.signup" />
        </a>
      </div>

      <button
        type="button"
        class="mx-hamburger"
        aria-expanded="false"
        aria-controls="mx-mobile-drawer"
        aria-label="Open navigation menu"
        id="mx-hamburger-btn"
      >
        <span></span>
        <span></span>
        <span></span>
      </button>
    </nav>
  </div>

  <div
    id="mx-mobile-drawer"
    class="mx-mobile-drawer"
    role="dialog"
    aria-modal="true"
    aria-labelledby="mx-mobile-drawer-title"
    hidden
  >
    <div class="mx-mobile-drawer-inner">
      <h2 id="mx-mobile-drawer-title" class="sr-only">Navigation</h2>
      <button
        type="button"
        class="mx-mobile-close"
        aria-label="Close navigation menu"
        data-mx-close
      >
        <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
          <path d="M3 3L15 15M15 3L3 15" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
        </svg>
      </button>
      <ul role="list" class="mx-mobile-links">
        {navLinks.map((l) => (
          <li><a href={l.href} data-mx-close><T k={l.k} /></a></li>
        ))}
      </ul>

      {/* Mirror of the EN/中 toggle so mobile users can switch language too.
          Same `data-mx-lang` hook → the inline JS keeps both groups in sync. */}
      <div class="mx-mobile-lang">
        <div
          class="mx-lang-toggle"
          role="group"
          aria-label="Language / 語言"
          data-mx-lang-group
        >
          <button
            type="button"
            class="mx-lang-toggle__btn"
            data-mx-lang="en"
            aria-pressed="true"
          >EN</button>
          <button
            type="button"
            class="mx-lang-toggle__btn"
            data-mx-lang="zh"
            aria-pressed="false"
          >中</button>
        </div>
      </div>

      <div class="mx-mobile-cta">
        <a class="mx-btn mx-btn-secondary" href={`${APP_BASE}/signin`} data-mx-close>
          <T k="nav.signin" />
        </a>
        <a class="mx-btn mx-btn-primary" href="/get-access" data-mx-close>
          <T k="nav.signup" />
        </a>
      </div>
    </div>
  </div>
</header>

<style>
  .mx-navbar-wrap {
    position: sticky;
    top: 0;
    z-index: 100;
    padding-top: 14px;
    padding-bottom: 6px;
  }

  .mx-navbar {
    display: flex;
    align-items: center;
    gap: 22px;
    padding: 8px 18px;
    background: var(--mx-glass-bg-strong);
    backdrop-filter: var(--mx-glass-blur);
    -webkit-backdrop-filter: var(--mx-glass-blur);
    border: 1px solid var(--mx-glass-border);
    border-radius: 999px;
    box-shadow:
      0 8px 32px rgba(0, 0, 0, 0.45),
      0 0 60px rgba(168, 85, 247, 0.04),
      inset 0 1px 0 rgba(255, 255, 255, 0.04);
    transition: padding 0.22s ease, border-color 0.22s ease,
      box-shadow 0.22s ease, background 0.22s ease;
  }
  /* Scrolled state — tighter pill, slightly stronger border */
  .mx-navbar-wrap[data-scrolled='true'] .mx-navbar {
    padding: 6px 16px;
    border-color: rgba(168, 85, 247, 0.26);
    background: rgba(7, 4, 13, 0.92);
    box-shadow:
      0 12px 36px rgba(0, 0, 0, 0.55),
      0 0 60px rgba(168, 85, 247, 0.06),
      inset 0 1px 0 rgba(255, 255, 255, 0.05);
  }
  .mx-navbar-wrap[data-scrolled='true'] .mx-logo { height: 38px; }

  .mx-brand {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
    user-select: none;
    transition: filter 0.18s ease;
    flex: 0 0 auto;
  }
  .mx-brand:hover .mx-logo {
    filter: drop-shadow(0 0 22px rgba(168, 85, 247, 0.42));
  }
  .mx-logo {
    height: 44px;
    width: auto;
    display: block;
    filter: drop-shadow(0 0 14px rgba(168, 85, 247, 0.22));
    transition: filter 0.18s ease, height 0.22s ease;
  }
  .mx-logo-text {
    font-family: var(--mx-font-display);
    font-size: 1.45rem;
    font-weight: 700;
    background: linear-gradient(135deg, #c084fc 0%, #a855f7 35%, #fbbf24 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    letter-spacing: -0.5px;
    line-height: 1;
  }

  .mx-nav-links {
    display: flex;
    align-items: center;
    gap: 26px;
    list-style: none;
    margin: 0;
    padding: 0;
    flex: 1 1 auto;
    justify-content: center;
  }
  .mx-nav-links a {
    font-family: var(--mx-font-body);
    font-size: 0.92rem;
    font-weight: 500;
    color: var(--mx-text-muted);
    letter-spacing: -0.1px;
    transition: color 0.18s ease;
    text-decoration: none;
    padding: 8px 4px;
  }
  .mx-nav-links a:hover { color: var(--mx-gold); }

  .mx-nav-cta {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    flex: 0 0 auto;
  }
  .mx-nav-cta .mx-btn {
    min-height: 40px;
    padding: 8px 18px;
    font-size: 0.9rem;
  }

  /* Hamburger — hidden on desktop */
  .mx-hamburger {
    display: none;
    width: 44px;
    height: 44px;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 5px;
    background: rgba(168, 85, 247, 0.08);
    border: 1px solid var(--mx-border-strong);
    border-radius: 999px;
    cursor: pointer;
    padding: 0;
  }
  .mx-hamburger span {
    display: block;
    width: 18px;
    height: 2px;
    background: var(--mx-text);
    border-radius: 2px;
    transition: transform 0.2s ease, opacity 0.2s ease;
  }
  .mx-hamburger[aria-expanded='true'] span:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }
  .mx-hamburger[aria-expanded='true'] span:nth-child(2) { opacity: 0; }
  .mx-hamburger[aria-expanded='true'] span:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  /* Mobile drawer */
  .mx-mobile-drawer {
    position: fixed;
    inset: 0;
    z-index: 200;
    background: rgba(7, 4, 13, 0.92);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    display: none;
  }
  .mx-mobile-drawer[data-open='true'] {
    display: flex;
  }
  .mx-mobile-drawer-inner {
    position: relative;
    margin: 90px auto 0 auto;
    padding: 32px 28px;
    width: min(360px, calc(100% - 32px));
    background: var(--mx-glass-bg-strong);
    backdrop-filter: var(--mx-glass-blur);
    border: 1px solid var(--mx-glass-border);
    border-radius: var(--mx-radius-lg);
  }
  .mx-mobile-close {
    position: absolute;
    top: 14px;
    right: 14px;
    width: 40px;
    height: 40px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: rgba(168, 85, 247, 0.06);
    border: 1px solid var(--mx-border-strong);
    border-radius: 999px;
    color: var(--mx-text-2);
    cursor: pointer;
    transition: color 0.18s ease, border-color 0.18s ease, background 0.18s ease;
  }
  .mx-mobile-close:hover {
    color: var(--mx-gold);
    border-color: rgba(251, 191, 36, 0.4);
    background: rgba(251, 191, 36, 0.08);
  }
  .mx-mobile-links {
    list-style: none;
    margin: 0 0 20px 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .mx-mobile-links a {
    display: flex;
    align-items: center;
    min-height: 48px;
    padding: 12px 14px;
    font-family: var(--mx-font-display);
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--mx-text);
    border-radius: 12px;
    transition: background 0.15s ease, color 0.15s ease;
  }
  .mx-mobile-links a:hover {
    background: rgba(168, 85, 247, 0.08);
    color: var(--mx-gold);
  }

  .mx-mobile-lang {
    display: flex;
    justify-content: center;
    margin: 0 0 20px 0;
  }

  .mx-mobile-cta {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .mx-mobile-cta .mx-btn { width: 100%; }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  /* Tablet — keep nav-links visible, tighter spacing */
  @media (max-width: 1024px) {
    .mx-nav-links { gap: 18px; }
    .mx-navbar { gap: 16px; padding: 8px 16px; }
    .mx-nav-links a { font-size: 0.88rem; }
    .mx-nav-cta { gap: 8px; }
    .mx-nav-cta .mx-btn { padding: 7px 14px; font-size: 0.86rem; }
  }
  /* Narrow tablet — drop sign-in (kept in drawer), keep CTA + lang toggle */
  @media (max-width: 900px) {
    .mx-nav-links { display: none; }
    .mx-nav-cta .mx-nav-signin { display: none; }
  }
  /* Mobile — collapse to hamburger */
  @media (max-width: 768px) {
    .mx-navbar-wrap { padding-top: 8px; }
    .mx-navbar { padding: 6px 12px; gap: 12px; }
    .mx-logo { height: 38px; }
    .mx-logo-text { font-size: 1.2rem; }
    .mx-nav-cta { display: none; }
    .mx-hamburger { display: inline-flex; }
  }
  @media (max-width: 380px) {
    .mx-logo-text { display: none; }
  }
</style>

<script is:inline>
  // ─── Mobile drawer + EN/中 language toggle ─────────────────────────────
  // Both run from the same IIFE so they share scope. No framework.
  (function () {
    // ── Mobile drawer ────────────────────────────────────────────────────
    const btn = document.getElementById('mx-hamburger-btn');
    const drawer = document.getElementById('mx-mobile-drawer');
    if (btn && drawer) {
      const setOpen = (open) => {
        btn.setAttribute('aria-expanded', String(open));
        if (open) {
          drawer.removeAttribute('hidden');
          drawer.dataset.open = 'true';
          document.body.style.overflow = 'hidden';
        } else {
          drawer.dataset.open = 'false';
          drawer.setAttribute('hidden', '');
          document.body.style.overflow = '';
        }
      };

      btn.addEventListener('click', () => {
        const open = btn.getAttribute('aria-expanded') === 'true';
        setOpen(!open);
      });

      drawer.addEventListener('click', (e) => {
        const target = e.target;
        if (!(target instanceof Element)) return;
        if (target === drawer) setOpen(false);
        if (target.closest('[data-mx-close]')) setOpen(false);
      });

      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && btn.getAttribute('aria-expanded') === 'true') {
          setOpen(false);
          btn.focus();
        }
      });
    }

    // ── EN / 中 language toggle ──────────────────────────────────────────
    // The pre-paint script in PublicLayout.astro has already set
    // <html lang> from the `moatrics_lang` cookie (default 'en'), so
    // CSS dual-render in <T> is already showing the right copy. All we
    // do here is: sync `aria-pressed` to match, and wire button clicks
    // to update the cookie + <html lang> + every toggle group on the
    // page (desktop + mobile drawer in sync).
    const COOKIE = 'moatrics_lang';
    const VALID = ['en', 'zh'];

    function syncPressed(lang) {
      document.querySelectorAll('[data-mx-lang]').forEach((b) => {
        b.setAttribute(
          'aria-pressed',
          String(b.getAttribute('data-mx-lang') === lang),
        );
      });
    }

    function setLang(lang) {
      if (!VALID.includes(lang)) return;
      document.documentElement.setAttribute('lang', lang);
      try {
        // 1 year. SameSite=Lax so external referrers (Google) still see
        // the cookie on first request to moatrics.com.
        document.cookie =
          COOKIE + '=' + lang + '; path=/; max-age=31536000; SameSite=Lax';
      } catch (e) {
        /* no-op: some sandboxed contexts block cookie writes */
      }
      syncPressed(lang);
    }

    // Initial sync — trust what the pre-paint script set on <html>.
    const initial = document.documentElement.getAttribute('lang') || 'en';
    syncPressed(VALID.includes(initial) ? initial : 'en');

    document.querySelectorAll('[data-mx-lang]').forEach((b) => {
      b.addEventListener('click', () => {
        setLang(b.getAttribute('data-mx-lang'));
      });
    });

    // ── Scroll-state — tighten navbar after 12px of scroll ──────────────
    const wrap = document.getElementById('mx-navbar-wrap');
    if (wrap) {
      const sync = () => {
        wrap.setAttribute('data-scrolled', String(window.scrollY > 12));
      };
      sync();
      window.addEventListener('scroll', sync, { passive: true });
    }
  })();
</script>
