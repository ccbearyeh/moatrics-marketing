---
/**
 * Sticky pill-shaped glass navbar with gold gradient wordmark.
 *
 * Auth links go to `app.moatrics.com` — the Streamlit app subdomain.
 * Below 768px we render a hamburger drawer instead of inline links.
 */
import { t } from '../i18n';

const APP_BASE = 'https://app.moatrics.com';
const navLinks = [
  { href: '/#features', label: t('nav.features') },
  { href: '/#how-it-works', label: t('nav.how_it_works') },
  { href: '/#pricing', label: t('nav.pricing') },
];
---

<header class="mx-navbar-wrap">
  <div class="mx-container">
    <nav class="mx-navbar" aria-label="Primary">
      <a href="/" class="mx-brand" aria-label="Moatrics — home">
        <img
          src="/moatrics-logo.png"
          alt=""
          width="54"
          height="54"
          class="mx-logo"
          loading="eager"
          decoding="async"
        />
        <span class="mx-logo-text">Moatrics</span>
      </a>

      <ul class="mx-nav-links" role="list">
        {navLinks.map((l) => (
          <li><a href={l.href}>{l.label}</a></li>
        ))}
      </ul>

      <div class="mx-nav-cta">
        <a class="mx-btn mx-btn-secondary mx-nav-signin" href={`${APP_BASE}/signin`}>
          {t('nav.signin')}
        </a>
        <a class="mx-btn mx-btn-primary" href={`${APP_BASE}/signup`}>
          {t('nav.signup')}
        </a>
      </div>

      <button
        type="button"
        class="mx-hamburger"
        aria-expanded="false"
        aria-controls="mx-mobile-drawer"
        aria-label="Open navigation menu"
        id="mx-hamburger-btn"
      >
        <span></span>
        <span></span>
        <span></span>
      </button>
    </nav>
  </div>

  <div
    id="mx-mobile-drawer"
    class="mx-mobile-drawer"
    role="dialog"
    aria-modal="true"
    aria-labelledby="mx-mobile-drawer-title"
    hidden
  >
    <div class="mx-mobile-drawer-inner">
      <h2 id="mx-mobile-drawer-title" class="sr-only">Navigation</h2>
      <ul role="list" class="mx-mobile-links">
        {navLinks.map((l) => (
          <li><a href={l.href} data-mx-close>{l.label}</a></li>
        ))}
      </ul>
      <div class="mx-mobile-cta">
        <a class="mx-btn mx-btn-secondary" href={`${APP_BASE}/signin`} data-mx-close>
          {t('nav.signin')}
        </a>
        <a class="mx-btn mx-btn-primary" href={`${APP_BASE}/signup`} data-mx-close>
          {t('nav.signup')}
        </a>
      </div>
    </div>
  </div>
</header>

<style>
  .mx-navbar-wrap {
    position: sticky;
    top: 0;
    z-index: 100;
    padding-top: 14px;
    padding-bottom: 6px;
  }

  .mx-navbar {
    display: flex;
    align-items: center;
    gap: 22px;
    padding: 10px 22px;
    background: var(--mx-glass-bg-strong);
    backdrop-filter: var(--mx-glass-blur);
    -webkit-backdrop-filter: var(--mx-glass-blur);
    border: 1px solid var(--mx-glass-border);
    border-radius: 999px;
    box-shadow:
      0 8px 32px rgba(0, 0, 0, 0.45),
      0 0 60px rgba(168, 85, 247, 0.04),
      inset 0 1px 0 rgba(255, 255, 255, 0.04);
  }

  .mx-brand {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
    user-select: none;
    transition: filter 0.18s ease;
    flex: 0 0 auto;
  }
  .mx-brand:hover .mx-logo {
    filter: drop-shadow(0 0 22px rgba(168, 85, 247, 0.42));
  }
  .mx-logo {
    height: 54px;
    width: auto;
    display: block;
    filter: drop-shadow(0 0 14px rgba(168, 85, 247, 0.22));
    transition: filter 0.18s ease;
  }
  .mx-logo-text {
    font-family: var(--mx-font-display);
    font-size: 1.65rem;
    font-weight: 700;
    background: linear-gradient(135deg, #c084fc 0%, #a855f7 35%, #fbbf24 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    letter-spacing: -0.6px;
    line-height: 1;
  }

  .mx-nav-links {
    display: flex;
    align-items: center;
    gap: 26px;
    list-style: none;
    margin: 0;
    padding: 0;
    flex: 1 1 auto;
    justify-content: center;
  }
  .mx-nav-links a {
    font-family: var(--mx-font-body);
    font-size: 0.92rem;
    font-weight: 500;
    color: var(--mx-text-muted);
    letter-spacing: -0.1px;
    transition: color 0.18s ease;
    text-decoration: none;
    padding: 8px 4px;
  }
  .mx-nav-links a:hover { color: var(--mx-gold); }

  .mx-nav-cta {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    flex: 0 0 auto;
  }
  .mx-nav-cta .mx-btn {
    min-height: 40px;
    padding: 8px 18px;
    font-size: 0.9rem;
  }

  /* Hamburger — hidden on desktop */
  .mx-hamburger {
    display: none;
    width: 44px;
    height: 44px;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 5px;
    background: rgba(168, 85, 247, 0.08);
    border: 1px solid var(--mx-border-strong);
    border-radius: 999px;
    cursor: pointer;
    padding: 0;
  }
  .mx-hamburger span {
    display: block;
    width: 18px;
    height: 2px;
    background: var(--mx-text);
    border-radius: 2px;
    transition: transform 0.2s ease, opacity 0.2s ease;
  }
  .mx-hamburger[aria-expanded='true'] span:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }
  .mx-hamburger[aria-expanded='true'] span:nth-child(2) { opacity: 0; }
  .mx-hamburger[aria-expanded='true'] span:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  /* Mobile drawer */
  .mx-mobile-drawer {
    position: fixed;
    inset: 0;
    z-index: 200;
    background: rgba(7, 4, 13, 0.92);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    display: none;
  }
  .mx-mobile-drawer[data-open='true'] {
    display: flex;
  }
  .mx-mobile-drawer-inner {
    margin: 90px auto 0 auto;
    padding: 32px 28px;
    width: min(360px, calc(100% - 32px));
    background: var(--mx-glass-bg-strong);
    backdrop-filter: var(--mx-glass-blur);
    border: 1px solid var(--mx-glass-border);
    border-radius: var(--mx-radius-lg);
  }
  .mx-mobile-links {
    list-style: none;
    margin: 0 0 24px 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .mx-mobile-links a {
    display: flex;
    align-items: center;
    min-height: 48px;
    padding: 12px 14px;
    font-family: var(--mx-font-display);
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--mx-text);
    border-radius: 12px;
    transition: background 0.15s ease, color 0.15s ease;
  }
  .mx-mobile-links a:hover {
    background: rgba(168, 85, 247, 0.08);
    color: var(--mx-gold);
  }
  .mx-mobile-cta {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .mx-mobile-cta .mx-btn { width: 100%; }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  @media (max-width: 900px) {
    .mx-nav-links { display: none; }
    .mx-nav-cta .mx-nav-signin { display: none; }
  }
  @media (max-width: 768px) {
    .mx-navbar-wrap { padding-top: 8px; }
    .mx-navbar { padding: 8px 14px; gap: 12px; }
    .mx-logo { height: 42px; }
    .mx-logo-text { font-size: 1.35rem; }
    .mx-nav-cta { display: none; }
    .mx-hamburger { display: inline-flex; }
  }
  @media (max-width: 380px) {
    .mx-logo-text { display: none; }
  }
</style>

<script is:inline>
  // Minimal vanilla JS for the mobile drawer.
  // No framework — runs once on every page load.
  (function () {
    const btn = document.getElementById('mx-hamburger-btn');
    const drawer = document.getElementById('mx-mobile-drawer');
    if (!btn || !drawer) return;

    const setOpen = (open) => {
      btn.setAttribute('aria-expanded', String(open));
      if (open) {
        drawer.removeAttribute('hidden');
        drawer.dataset.open = 'true';
        document.body.style.overflow = 'hidden';
      } else {
        drawer.dataset.open = 'false';
        drawer.setAttribute('hidden', '');
        document.body.style.overflow = '';
      }
    };

    btn.addEventListener('click', () => {
      const open = btn.getAttribute('aria-expanded') === 'true';
      setOpen(!open);
    });

    drawer.addEventListener('click', (e) => {
      const target = e.target;
      if (!(target instanceof Element)) return;
      // Click outside inner panel — close
      if (target === drawer) setOpen(false);
      if (target.closest('[data-mx-close]')) setOpen(false);
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && btn.getAttribute('aria-expanded') === 'true') {
        setOpen(false);
        btn.focus();
      }
    });
  })();
</script>
